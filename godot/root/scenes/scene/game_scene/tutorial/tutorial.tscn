[node name="Welcome" parent="PanelContainer/VBoxContainer/TabContainer" unique_id=202632296 instance=ExtResource("1_3k5bi")]
layout_mode = 2
title = "Welcome to Rememburger!"
text = "Customers are lining up! Take their orders, cook their burgers, and serve them before they lose patience.

Each customer comes with a tip that drops over time. Serve them fast to earn more!

You have 5 minutes to earn as much money as you can."
image = ExtResource("2_cxpb3")
metadata/_tab_index = 0

[node name="Orders" parent="PanelContainer/VBoxContainer/TabContainer" unique_id=1785599928 instance=ExtResource("1_3k5bi")]
visible = false
layout_mode = 2
title = "Take Orders and Remember Them"
text = "When a customer reaches the counter, they'll tell you what they want.

[b]<Take Order>[/b] to accept it (tip  [color=FOREST_GREEN]+20€[/color]).
[b]<Send Back>[/b] to push them to the back of the line (tip [color=ORANGE_RED]-2€[/color]).

But be careful: once accepted, their order won't be shown again. You'll have to remember it!"
image = ExtResource("4_pfone")
metadata/_tab_index = 1

[node name="Kitchen" parent="PanelContainer/VBoxContainer/TabContainer" unique_id=969362812 instance=ExtResource("1_3k5bi")]
visible = false
layout_mode = 2
title = "In the Kitchen"
text = "[b]Left-click[/b] to grab an item, [b]left-click[/b] again to place it. [b]Right-click[/b] on a plate to undo the top ingredient.

To build a burger: grab a plate, add a bottom bun, stack ingredients, then a top bun.

Use the grill for steaks, the cutting board for veggies, and sauce bottles directly on your plate."
image = ExtResource("5_c4plt")
metadata/_tab_index = 2

[node name="Serve" parent="PanelContainer/VBoxContainer/TabContainer" unique_id=2012283745 instance=ExtResource("1_3k5bi")]
visible = false
layout_mode = 2
title = "Serve to Score"
text = "Grab your plate and drop it on the serving area. The closer the burger matches the order, the more you earn.

Don't keep them waiting — [b][shake rate=15.0 level=5 connected=0]tips shrink every second![/shake]"
image = ExtResource("6_kqrg2")
metadata/_tab_index = 3

